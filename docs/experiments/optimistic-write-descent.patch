+// ---------- optimistic write descent ----------
+
+/// Descend the upper blobs OPTIMISTICALLY (LeanStore-style optimistic
+/// lock coupling) toward the *target* blob where the mutation for
+/// `key` will land, recording a `parent_chain` of `(pin, version,
+/// child_guid, child_depth)` per crossing.
+///
+/// This mirrors the read path [`lookup_multi_with`]:
+/// - each blob is read under [`CachedBlob::read_optimistic`], then
+///   `validate()`d after consuming any borrowed data — a torn read
+///   restarts from the root;
+/// - each crossing is re-confirmed under a SHORT `parent.read()`
+///   (shared) latch, exactly as [`pin_validated_child`] does, before
+///   the child is pinned and the parent latch dropped. NEVER are two
+///   blobs latched simultaneously.
+///
+/// Unlike the read path, the parent pins are retained in `parent_chain`
+/// so the caller can re-validate every ancestor's version *after*
+/// taking the target's exclusive guard and *before* mutating (the
+/// validate-before-mutate hazard closure).
+///
+/// Returns:
+/// - [`DescentResult::Reached`] when `lookup_at` resolves the key
+///   WITHIN a blob (Found/NotFound — not Crossing); that blob is the
+///   target. The target pin is returned unlatched; the caller takes
+///   the single `write()`.
+/// - [`DescentResult::LandsInRoot`] when the key resolves within the
+///   root blob (no crossing).
+/// - [`DescentResult::Escalate`] when a blob on the path is
+///   snapshot-shared (CoW fork needs the parent's exclusive latch).
+/// - [`DescentResult::Restart`] on a torn optimistic read / moved
+///   crossing — the caller bumps `note_optimistic_restart` and retries.
+pub(super) fn optimistic_descend_to_target(
+    bm: &BufferManager,
+    root_pin: &Arc<CachedBlob>,
+    route_cache: Option<&RouteCache>,
+    key: SearchKey<'_>,
+) -> Result<DescentResult> {
+    // Hop 0: the cached root blob, read optimistically.
+    let crossing = {
+        let root_version = root_pin.content_version();
+        let guard = root_pin.read_optimistic();
+        let frame = BlobFrameRef::wrap(guard.as_slice());
+        let root_slot = frame.header().root_slot;
+        let result = lookup_at(frame, root_slot, key, 0);
+        if !guard.validate() || !root_pin.validate_content_version(root_version) {
+            return Ok(DescentResult::Restart);
+        }
+        match result {
+            Err(e) => return Err(e),
+            // Resolves within the root blob — no crossing.
+            Ok(LookupResult::Found(_) | LookupResult::NotFound) => {
+                return Ok(DescentResult::LandsInRoot);
+            }
+            Ok(LookupResult::Crossing(crossing)) => crossing,
+        }
+    };
+
+    let mut parent_chain: Vec<ParentChainEntry> = Vec::new();
+
+    // Re-confirm + pin the root's child under a short shared latch.
+    let (mut pin, mut depth) = match pin_validated_child_for_write(
+        bm,
+        route_cache,
+        key,
+        root_pin,
+        0,
+        crossing,
+        &mut parent_chain,
+    )? {
+        ChildPin::Pinned(pin, depth) => (pin, depth),
+        ChildPin::Moved => return Ok(DescentResult::Restart),
+        ChildPin::SnapshotShared => {
+            return Ok(DescentResult::Escalate(EscalationReason::SnapshotSharedChild));
+        }
+    };
+
+    // Cross-blob hops, all optimistic. On a torn read or moved crossing
+    // we restart the whole descent from the root (the parent BlobNode
+    // that pointed here may also have moved).
+    loop {
+        pin.prefetch_header();
+        // Optimistic read of this blob. Capture only the crossing (which
+        // borrows nothing from the frame) so the guard can be dropped
+        // before we potentially move `pin` into the `Reached` result.
+        let crossing = {
+            let version = pin.content_version();
+            let guard = pin.read_optimistic();
+            let frame = BlobFrameRef::wrap(guard.as_slice());
+            let start_slot = frame.header().root_slot;
+            let result = lookup_at(frame, start_slot, key, depth);
+            if !guard.validate() || !pin.validate_content_version(version) {
+                return Ok(DescentResult::Restart);
+            }
+            match result {
+                Err(e) => return Err(e),
+                // Resolves within this blob — it is the target. The
+                // optimistic guard is dropped at the end of this block,
+                // releasing the borrow on `pin` so it can be moved out.
+                Ok(LookupResult::Found(_) | LookupResult::NotFound) => None,
+                Ok(LookupResult::Crossing(crossing)) => Some(crossing),
+            }
+        };
+        let Some(crossing) = crossing else {
+            return Ok(DescentResult::Reached {
+                target_pin: pin,
+                target_depth: depth,
+                parent_chain,
+            });
+        };
+
+        let (child_pin, child_depth) = match pin_validated_child_for_write(
+            bm,
+            route_cache,
+            key,
+            &pin,
+            depth,
+            crossing,
+            &mut parent_chain,
+        )? {
+            ChildPin::Pinned(p, d) => (p, d),
+            ChildPin::Moved => return Ok(DescentResult::Restart),
+            ChildPin::SnapshotShared => {
+                return Ok(DescentResult::Escalate(EscalationReason::SnapshotSharedChild));
+            }
+        };
+        pin = child_pin;
+        depth = child_depth;
+    }
+}
+
+/// Result of re-confirming + pinning a crossing's child on the write
+/// descent.
+enum ChildPin {
+    /// Child pinned; carries the child pin + the depth to continue at.
+    Pinned(Arc<CachedBlob>, usize),
+    /// The crossing moved under us (torn parent edge) — restart.
+    Moved,
+    /// The child may be visible to a live snapshot → CoW fork needs the
+    /// parent's exclusive latch → escalate to the pessimistic path.
+    SnapshotShared,
+}
+
+/// Write-path mirror of [`pin_validated_child`]. Re-confirms the
+/// crossing edge under a SHORT shared latch on `parent_pin`, snapshots
+/// the parent's `content_version` under that same latch, pins the
+/// child, then drops the parent latch. NEVER holds two latches at once.
+///
+/// Differs from the read-path helper in three ways:
+/// 1. After pinning the child it checks [`child_is_snapshot_shared`]; a
+///    snapshot-shared child needs a CoW fork (parent exclusive latch),
+///    so the fast path cannot proceed → [`ChildPin::SnapshotShared`].
+/// 2. It learns the route ONLY after the edge re-confirm succeeds AND
+///    the child is not snapshot-shared (rule #5: learn with the SAME
+///    version that was validated).
+/// 3. It pushes a [`ParentChainEntry`] (parent pin + snapshotted
+///    version) so the caller can re-validate the full chain before
+///    mutating.
+#[allow(clippy::too_many_arguments)]
+fn pin_validated_child_for_write(
+    bm: &BufferManager,
+    route_cache: Option<&RouteCache>,
+    key: SearchKey<'_>,
+    parent_pin: &Arc<CachedBlob>,
+    parent_depth: usize,
+    expected: BlobNodeCrossing,
+    parent_chain: &mut Vec<ParentChainEntry>,
+) -> Result<ChildPin> {
+    let parent_guard = parent_pin.read();
+    let parent_version = parent_pin.content_version();
+    let actual = {
+        let frame = BlobFrameRef::wrap(parent_guard.as_slice());
+        match lookup_at(frame, frame.header().root_slot, key, parent_depth)? {
+            LookupResult::Crossing(crossing)
+                if crossing.child_guid == expected.child_guid
+                    && crossing.child_depth == expected.child_depth =>
+            {
+                crossing
+            }
+            LookupResult::Crossing(_) | LookupResult::Found(_) | LookupResult::NotFound => {
+                return Ok(ChildPin::Moved);
+            }
+        }
+    };
+    let parent_guid: BlobGuid = BlobFrameRef::wrap(parent_guard.as_slice())
+        .header()
+        .blob_guid;
+
+    let child_pin = bm.pin(actual.child_guid)?;
+    child_pin.prefetch_header();
+    // CoW: a snapshot-shared child must be forked under the parent's
+    // exclusive latch — the fast path can't do that, so escalate. The
+    // route is intentionally NOT learned in this case (the pessimistic
+    // path will fork + re-establish the edge).
+    if child_is_snapshot_shared(bm, child_pin.as_ref()) {
+        drop(parent_guard);
+        return Ok(ChildPin::SnapshotShared);
+    }
+
+    if let Some(cache) = route_cache {
+        cache.learn(
+            key,
+            parent_guid,
+            parent_depth,
+            parent_version,
+            actual.child_guid,
+            actual.child_depth,
+        );
+        bm.mark_route_resident(actual.child_guid);
+    }
+    // Record the crossing for the post-target-latch chain re-validation.
+    // The version snapshotted here is stable under `parent_guard` and is
+    // exactly the version the route-cache learned, so a later
+    // `validate_content_version(version)` mismatch means the ancestor
+    // mutated structurally after we crossed it.
+    parent_chain.push(ParentChainEntry {
+        pin: Arc::clone(parent_pin),
+        version: parent_version,
+    });
+    drop(parent_guard);
+    Ok(ChildPin::Pinned(child_pin, actual.child_depth))
+}
+
+/// Re-validate (version-only) every recorded ancestor crossing. Sound
+/// because every structural mutation bumps the blob's content version
+/// on `release_exclusive` — the same trust model the read path uses.
+///
+/// MUST be called AFTER the target's exclusive guard is taken and
+/// BEFORE any mutation (the sacred validate-before-mutate ordering).
+/// Returns `false` on any mismatch → the caller drops the target guard
+/// and restarts from the root.
+#[must_use]
+pub(super) fn revalidate_parent_chain(parent_chain: &[ParentChainEntry]) -> bool {
+    parent_chain
+        .iter()
+        .all(|entry| entry.pin.validate_content_version(entry.version))
+}
