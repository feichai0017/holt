+/// (snapshot-shared blob on the path) or restart-budget exhaustion.
+/// Result of one optimistic erase attempt (mirror of
+/// `super::insert::OptimisticAttempt`).
+enum OptimisticEraseAttempt {
+    Done(EraseOutcome),
+    Restart,
+    Escalate,
